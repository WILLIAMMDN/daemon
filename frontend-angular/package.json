{
  "name": "frontend-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration cloud",
    "start:cloud": "ng serve --configuration cloud",
    "start:local": "ng serve --configuration development",
    "build": "ng build",
    "build:staging": "node scripts/generate-staging-environment.mjs && ng build --configuration staging",
    "watch": "ng build --watch --configuration development",
    "check:architecture": "node scripts/check-architecture.mjs",
    "check:student-visual": "node scripts/check-student-visual.mjs",
    "test": "jest",
    "test:ci": "npm run check:architecture && npm run check:student-visual && jest --runInBand --coverage",
    "test:watch": "jest --watch",
    "e2e": "playwright test",
    "e2e:public": "playwright test --project=public"
  },
  "private": true,
  "packageManager": "npm@11.16.0",
  "overrides": {
    "@babel/core": "7.29.7",
    "@angular/build": {
      "undici": "7.28.0"
    }
  },
  "dependencies": {
    "@angular/cdk": "21.0.0",
    "@angular/common": "^21.2.18",
    "@angular/compiler": "^21.2.18",
    "@angular/core": "^21.2.18",
    "@angular/forms": "^21.2.18",
    "@angular/platform-browser": "^21.2.18",
    "@angular/router": "^21.2.18",
    "@angular/service-worker": "^21.2.18",
    "@fortawesome/angular-fontawesome": "^4.0.0",
    "@fortawesome/free-brands-svg-icons": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@rive-app/canvas": "^2.38.2",
    "@sentry/angular": "^10.65.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "deep-chat": "^2.4.2",
    "driver.js": "^1.6.0",
    "firebase": "^12.15.0",
    "laravel-echo": "^2.3.7",
    "ng-zorro-antd": "^21.3.2",
    "ng2-charts": "^10.0.0",
    "ngx-spinner": "^21.1.0",
    "pusher-js": "^8.5.0",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.5.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.18",
    "@angular/cli": "^21.2.18",
    "@angular/compiler-cli": "^21.2.18",
    "@angular/platform-browser-dynamic": "^21.2.18",
    "@emnapi/core": "1.11.2",
    "@emnapi/runtime": "1.11.2",
    "@emnapi/wasi-threads": "1.2.2",
    "@playwright/test": "^1.42.1",
    "@types/jest": "^30.0.0",
    "autoprefixer": "^10.5.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-preset-angular": "^17.0.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.2"
  }
}
