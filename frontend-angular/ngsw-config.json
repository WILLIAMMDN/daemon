{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/styles-*.css",
          "/main-*.js",
          "/polyfills-*.js"
        ]
      }
    },
    {
      "name": "lazy-chunks",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/*.js", "/*.css"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/img/**/*",
          "/rive/**/*"
        ]
      }
    }
  ],
  "dataGroups": []
}
