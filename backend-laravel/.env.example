APP_NAME=DAEMON
APP_ENV=local
APP_VERSION=development
APP_COMMIT=unknown
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

DB_CONNECTION=pgsql
DB_HOST=aws-1-sa-east-1.pooler.supabase.com
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres.lbxdcvsrmkkynttgwblc
DB_PASSWORD=
DB_SSLMODE=require

# Para migrar datos desde MySQL local hacia Supabase/PostgreSQL.
# Se usa solo con: php artisan daemon:migrar-a-supabase
LEGACY_DB_HOST=127.0.0.1
LEGACY_DB_PORT=3306
LEGACY_DB_DATABASE=iaparateens_db
LEGACY_DB_USERNAME=root
LEGACY_DB_PASSWORD=

FRONTEND_URL=http://localhost:4200
FRONTEND_PRODUCTION_URL=https://daemonestudiante.web.app
FRONTEND_EMAIL_VERIFICATION_URL=https://daemonestudiante.web.app/verificar-correo
CORS_SUPPORTS_CREDENTIALS=true
SANCTUM_TOKEN_EXPIRATION=480
AUTH_COOKIE_NAME=daemon_access
# Defaults para desarrollo local por HTTP.
# En Render/produccion: usar AUTH_COOKIE_SAME_SITE=none y AUTH_COOKIE_SECURE=true
# o quitar estos overrides para dejar que config/daemon.php use APP_ENV=production.
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
AUTH_EXPOSE_BEARER_TOKEN=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT=http://localhost:4200/login
FIREBASE_PROJECT_ID=daemon-a41f8
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_PASSWORD_RESET_URL=https://daemonestudiante.web.app/restablecer-clave
FIREBASE_AUTH_LINK_DOMAIN=
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma2:9b

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

